    end

    (*Promotion*)
    else if promotion_piece <> 0 then begin
      unmake_aux position (white_to_move lxor 1) pieces_bitboard piece from to_ captured_piece;
    end

    (*Push or normal capture*)
    else begin
      unmake_aux position (white_to_move lxor 1) pieces_bitboard piece from to_ captured_piece
    end
  end

