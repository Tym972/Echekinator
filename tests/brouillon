let [@inline] unmake_aux position white_to_move pieces_bitboard piece from to_ captured_piece =
  if captured_piece = 0 then begin
    quiet_bitboard_update position white_to_move pieces_bitboard piece from to_
  end
  else begin
    capture_bitboard_update position white_to_move pieces_bitboard piece from to_ captured_piece to_
  end

let unmake_light position move =
  let white_to_move = position.white_to_move in
  let pieces_bitboard = position.pieces in
  let player_pieces = pieces_rep.(white_to_move) in
  position.white_to_move <- position.white_to_move lxor 1;
  let from = get_move_from move in
  let to_ = get_move_to move in
  let piece = get_move_piece move in
  let promotion_piece = get_move_promotion move in
  let captured_piece = position.state.(position.ply).captured_piece in

  (*Pawn moves*)
  if is_pawn piece then begin

    (*En passant*)
